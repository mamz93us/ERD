# ─────────────────────────────────────────────────────────────────
# Adly Group Agency CRMS — Production / Staging .env template
# ─────────────────────────────────────────────────────────────────
# Copy this file to .env on the cPanel server, then fill in every
# value marked CHANGE_ME. Do NOT commit the real .env to git.
#
# Generate APP_KEY on the server with:  php artisan key:generate
# ─────────────────────────────────────────────────────────────────

APP_NAME="Adly Group Agency"
APP_ENV=staging
APP_KEY=
APP_DEBUG=false
APP_URL=https://erd.aladly-group.com
APP_TIMEZONE=Africa/Cairo

APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ─── Logging ───────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# ─── Database (cPanel MySQL/MariaDB) ───────────────────────────────
# Replace with the exact strings cPanel hands out (always prefixed
# with your cpanel username, e.g. aladly_adly_crms).
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=CHANGE_ME_cpaneluser_adly_crms
DB_USERNAME=CHANGE_ME_cpaneluser_adly_app
DB_PASSWORD=CHANGE_ME_strong_password

# ─── Sessions / Cache / Queue (all DB-backed — no Redis) ───────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.aladly-group.com
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# ─── Mail (Amazon SES SMTP, configured in Phase 9) ─────────────────
# For staging without notifications, leave MAIL_MAILER=log so outgoing
# mail dumps to storage/logs instead of failing.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=email-smtp.eu-west-1.amazonaws.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="no-reply@aladly-group.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─── Amazon SES (Phase 9; leave empty for staging) ─────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ─── WhatsApp via Green API (Phase 9; leave empty for staging) ────
GREEN_API_BASE_URL=https://api.green-api.com
GREEN_API_INSTANCE_ID=
GREEN_API_TOKEN=

# ─── Vite ──────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"

# ─── Force HTTPS in URL generation ────────────────────────────────
# AppServiceProvider::boot() reads this; set true on every non-local env.
FORCE_HTTPS=true
